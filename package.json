{
  "name": "live-board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:desktop": "pnpm --filter @live-board/desktop dev",
    "dev:overlay": "pnpm --filter @live-board/overlay dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "build": "pnpm -r --if-present build",
    "package:win": "pnpm --filter @live-board/desktop package:win",
    "package:win:dir": "pnpm --filter @live-board/desktop package:win:dir"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
