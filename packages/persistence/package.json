{
  "name": "@live-board/persistence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @live-board/obs-protocol build && vitest run"
  },
  "dependencies": {
    "@live-board/domain": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
